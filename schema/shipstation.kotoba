// Shipstation clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace shipstation {

    entity ContentEntry {
        id: string @unique
        modelName: string
        title: string
        locale: string
        published: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Product {
        id: string @unique
        sku: string
        title: string
        price: float
        currency: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Shipment {
        id: string @unique
        orderId: string
        carrier: string
        tracking: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity SearchIndex {
        id: string @unique
        name: string
        recordCount: integer
        primaryKey: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Webhook {
        id: string @unique
        event: string
        url: string
        active: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Order {
        id: string @unique
        number: string
        total: float
        currency: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
